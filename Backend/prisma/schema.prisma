generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PM
  DEVELOPER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  password       String
  role           Role
  refreshToken   String?
  createdAt      DateTime       @default(now())
  projects       Project[]      @relation("PMProjects")
  assignedTasks  Task[]         @relation("AssignedTasks")
  activityLogs   ActivityLog[]
  notifications  Notification[]
}

model Client {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id           String        @id @default(uuid())
  name         String
  description  String?
  client       Client        @relation(fields: [clientId], references: [id])
  clientId     String
  manager      User          @relation("PMProjects", fields: [managerId], references: [id])
  managerId    String
  tasks        Task[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())

  @@index([managerId])
  @@index([clientId])
}

model Task {
  id           String        @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus    @default(TODO)
  priority     Priority      @default(MEDIUM)
  dueDate      DateTime
  project      Project       @relation(fields: [projectId], references: [id])
  projectId    String
  assignee     User          @relation("AssignedTasks", fields: [assigneeId], references: [id])
  assigneeId   String
  activityLogs ActivityLog[]
  notifications Notification[]
  createdAt    DateTime      @default(now())

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
}

model ActivityLog {
  id         String     @id @default(uuid())
  user       User       @relation(fields: [userId], references: [id])
  userId     String
  project    Project    @relation(fields: [projectId], references: [id])
  projectId  String
  task       Task       @relation(fields: [taskId], references: [id])
  taskId     String
  fromStatus TaskStatus?
  toStatus   TaskStatus
  message    String
  createdAt  DateTime   @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([taskId])
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  task      Task?    @relation(fields: [taskId], references: [id])
  taskId    String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}